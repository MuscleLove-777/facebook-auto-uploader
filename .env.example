# Facebook Graph API
FB_PAGE_ID=あなたのFacebookページID（数字）
FB_PAGE_ACCESS_TOKEN=ページアクセストークン

# Facebook App（トークン更新用）
FB_APP_ID=Meta DevelopersのアプリID
FB_APP_SECRET=アプリシークレット

# Google Drive
GDRIVE_FOLDER_ID_FACEBOOK=GoogleDriveのフォルダID
GOOGLE_API_KEY=Google APIキー（Drive API用）

# LINE通知（オプション）
LINE_CHANNEL_TOKEN=LINEチャネルトークン
LINE_USER_ID=LINEユーザーID
